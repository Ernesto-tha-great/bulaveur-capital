{
  "name": "bulaveur-capital",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous fixed-income research firm: market data → research → compliance → approval → publish to X.",
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "verify": "tsx src/scripts/verify.ts",
    "sync:data": "tsx src/scripts/sync-data.ts",
    "seed:watchlist": "tsx src/scripts/seed-watchlist.ts",
    "mission": "tsx src/scripts/run-mission.ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "ingest": "tsx src/scripts/ingest.ts",
    "worker": "tsx src/core/queue/worker.ts",
    "eval": "vitest run tests/eval",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.86",
    "@ai-sdk/openai-compatible": "^1.0.30",
    "@hono/node-server": "^2.0.6",
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "@prisma/client": "^6.19.3",
    "ai": "^6.0.209",
    "bullmq": "^5.79.1",
    "dotenv": "^16.4.7",
    "hono": "^4.12.27",
    "ioredis": "^5.4.2",
    "langfuse": "^3.38.20",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
