# ── Models ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1
MODEL_LOCAL=qwen2.5:7b
MODEL_LOCAL_FAST=llama3.2:3b
MODEL_EMBED=nomic-embed-text
MODEL_OPEN=z-ai/glm-4.6
MODEL_FRONTIER=claude-sonnet-4-6
MODEL_FRONTIER_HARD=claude-opus-4-8

# ── Data services ────────────────────────────────────────────────────
DATABASE_URL=postgresql://bulaveur:bulaveur@localhost:5432/bulaveur?schema=public
REDIS_URL=redis://localhost:6379

# ── Observability (Langfuse cloud free tier or self-host) ────────────
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Market data ──────────────────────────────────────────────────────
# FRED (St. Louis Fed) — free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# SEC EDGAR requires a descriptive User-Agent: "Name email"
SEC_USER_AGENT=Bulaveur Capital research@yourdomain.com

# ── Publishing ───────────────────────────────────────────────────────
# X / Twitter: a user OAuth2 token with tweet.write scope.
X_ACCESS_TOKEN=
PUBLIC_BASE_URL=http://localhost:8080
# Newsletter (Resend) for the weekly credit note
RESEND_API_KEY=
NEWSLETTER_TO=
NEWSLETTER_FROM=Bulaveur Capital <research@yourdomain.com>

# ── Approvals (Telegram one-tap approve/reject) ──────────────────────
# Create a bot via @BotFather; get your chat id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Runtime ──────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
PORT=8080
MAX_RUN_BUDGET_CENTS=25
